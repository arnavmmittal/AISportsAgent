# ============================================
# DEVELOPMENT ENVIRONMENT
# ============================================
# Copy this to apps/web/.env.local for local development

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Local Supabase or dev instance)
DATABASE_URL=postgresql://postgres:postgres@localhost:54321/postgres
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # Your dev key

# Auth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=dev-secret-change-me-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# AI Services (use dev/test keys with rate limits)
OPENAI_API_KEY=sk-proj-dev-...
OPENAI_MODEL=gpt-3.5-turbo  # Cheaper for development
OPENAI_MAX_TOKENS=1000

# MCP Server (optional - local development)
MCP_SERVER_URL=http://localhost:8000
MCP_SERVICE_TOKEN=dev-service-token

# Feature Flags (Development)
ENABLE_DEMO_ACCOUNTS=true        # OK in dev
ENABLE_COST_LIMITS=false         # Unlimited for testing
ENABLE_VOICE=true
ENABLE_ADVANCED_ANALYTICS=true

# Monitoring (optional in dev)
SENTRY_DSN=                      # Leave empty or use dev project
LOG_LEVEL=debug

# WebSocket (for voice chat)
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3001
