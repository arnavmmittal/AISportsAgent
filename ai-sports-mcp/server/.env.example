# Application Settings
APP_NAME="AI Sports Psychology MCP Server"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT=development  # development, staging, production

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Cartesia.ai TTS (Optional - falls back to OpenAI TTS if not configured)
CARTESIA_API_KEY=  # Leave empty to use OpenAI TTS only
CARTESIA_VOICE_ID=voice-id-supportive
WHISPER_MODEL=whisper-1

# Vector Database (ChromaDB)
# Leave empty for local ChromaDB, or provide host/port for remote
CHROMA_HOST=
CHROMA_PORT=
CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_COLLECTION_NAME=sports_psychology_kb

# Authentication / Security
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-base64-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# NextAuth (from Next.js frontend)
NEXTAUTH_SECRET=your-nextauth-secret-from-nextjs
NEXTAUTH_URL=http://localhost:3000

# Crisis Detection Alerts
CRISIS_ALERT_EMAIL=sports-psychology-team@university.edu
CRISIS_ALERT_WEBHOOK=https://your-webhook-url.com/crisis-alert

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text

# Knowledge Base Processing
KB_CHUNK_SIZE=1000
KB_CHUNK_OVERLAP=200
KB_MIN_CHUNK_SIZE=100

# Agent Settings
DISCOVERY_MIN_QUESTIONS=5
DISCOVERY_MAX_QUESTIONS=10
