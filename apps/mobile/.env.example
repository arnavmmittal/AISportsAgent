# Mobile App Environment Variables
# Copy this file to .env.local and update with your values

# ===========================================
# Development (Local Testing)
# ===========================================

# Your computer's local IP address for development
# Mac: Run `ipconfig getifaddr en0`
# Windows: Run `ipconfig` and look for IPv4 Address
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Voice WebSocket URL (optional, auto-generated from API_URL if not set)
EXPO_PUBLIC_VOICE_URL=ws://localhost:8000

# Supabase Configuration (get from Supabase dashboard)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# EAS Build Configuration
# ===========================================
# These are injected automatically by EAS based on build profile
# - Staging builds use: https://staging-aisportsagent.vercel.app
# - Production builds use: https://app.aisportsagent.com
# No need to set these manually for builds

# ===========================================
# Notes
# ===========================================
# - .env.local is gitignored (never committed)
# - EAS builds use env vars from eas.json profiles
# - Changes to .env.local require app restart (not hot reload)
