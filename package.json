{
  "name": "flow-sports-coach-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:full": "concurrently --names \"MCP,NEXT\" --prefix-colors \"magenta,cyan\" \"pnpm dev:mcp\" \"pnpm dev:web\"",
    "dev:mcp": "cd ai-sports-mcp/server && ./scripts/dev.sh",
    "dev:web": "cd apps/web && pnpm dev",
    "dev:mobile": "cd apps/mobile && pnpm start",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "20.x"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    }
  }
}
