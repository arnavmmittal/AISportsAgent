# ============================================
# PRODUCTION ENVIRONMENT
# ============================================
# Deploy to Vercel production with these variables
# CRITICAL: Review security checklist before deployment

# Environment
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://app.aisportsagent.com

# Database (Production Supabase)
DATABASE_URL=postgresql://postgres.[PROD_PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[PROD_PROJECT].supabase.co
SUPABASE_ANON_KEY=eyJ...  # Production key
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # CRITICAL: Server-side only

# Auth (rotate every 90 days - set calendar reminder)
NEXTAUTH_SECRET=[ROTATE_EVERY_90_DAYS_CRITICAL]
NEXTAUTH_URL=https://app.aisportsagent.com

# AI Services (production keys with strict limits)
OPENAI_API_KEY=sk-proj-prod-...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000
ANTHROPIC_API_KEY=sk-ant-...  # Backup provider

# MCP Server (Railway production or AWS ECS)
MCP_SERVER_URL=https://mcp.aisportsagent.com
MCP_SERVICE_TOKEN=[PROD_SERVICE_TOKEN_ROTATE_YEARLY]

# Feature Flags (Production - CRITICAL SETTINGS)
ENABLE_DEMO_ACCOUNTS=false       # MUST BE FALSE - VERIFY BEFORE DEPLOY
ENABLE_COST_LIMITS=true          # MUST BE TRUE - PREVENTS RUNAWAY COSTS
COST_LIMIT_DAILY=500             # USD per tenant (circuit breaker)
COST_LIMIT_MONTHLY=10000         # USD total system limit
ENABLE_VOICE=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_CRISIS_ESCALATION=true    # MUST BE TRUE

# Monitoring (Required for production)
SENTRY_DSN=https://...@sentry.io/production
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1    # 10% sampling
LOG_LEVEL=warn                    # Only warnings and errors

# Rate Limiting (REQUIRED)
ENABLE_RATE_LIMITING=true         # MUST BE TRUE
RATE_LIMIT_PER_USER=60            # requests/minute
RATE_LIMIT_PER_TENANT=1000        # requests/minute
RATE_LIMIT_GLOBAL=10000           # system-wide limit

# Security
ENABLE_AUDIT_LOGGING=true         # MUST BE TRUE for FERPA compliance
AUDIT_LOG_RETENTION_DAYS=2555     # 7 years for FERPA

# WebSocket
NEXT_PUBLIC_WEBSOCKET_URL=wss://ws.aisportsagent.com

# External Services
DATADOG_API_KEY=                  # Optional: Advanced monitoring
POSTHOG_API_KEY=                  # Optional: Feature flags
