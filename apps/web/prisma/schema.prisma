generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Assignment {
  id                   String                 @id
  coachId              String
  title                String
  description          String
  dueDate              DateTime?
  targetAthleteIds     Json?
  targetSport          String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  AssignmentSubmission AssignmentSubmission[]

  @@index([coachId])
  @@index([dueDate])
}

model AssignmentSubmission {
  id           String           @id
  assignmentId String
  athleteId    String
  response     String?
  status       AssignmentStatus @default(PENDING)
  submittedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime
  Assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, athleteId])
  @@index([assignmentId])
  @@index([athleteId])
  @@index([status])
}

model Athlete {
  userId               String                @id
  sport                String
  year                 String
  teamPosition         String?
  consentCoachView     Boolean               @default(false)
  riskLevel            RiskLevel             @default(LOW)
  lastRiskUpdate       DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime
  consentChatSummaries Boolean               @default(false)
  User                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  ChatSession          ChatSession[]
  ChatSummary          ChatSummary[]
  ConversationInsight  ConversationInsight[]
  CrisisAlert          CrisisAlert[]
  Goal                 Goal[]
  MoodLog              MoodLog[]
  PerformanceMetric    PerformanceMetric[]
  ReadinessScore       ReadinessScore[]
  WearableData         WearableData[]

  @@index([riskLevel])
  @@index([sport])
}

model AuditLog {
  id           String   @id
  userId       String
  userRole     Role
  action       String
  resourceType String
  resourceId   String?
  athleteId    String?
  ipAddress    String?
  userAgent    String?
  timestamp    DateTime @default(now())

  @@index([action])
  @@index([athleteId, timestamp])
  @@index([userId, timestamp])
}

model ChatSession {
  id                  String                @id
  athleteId           String
  summary             String?
  topic               String?
  sentiment           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  Athlete             Athlete               @relation(fields: [athleteId], references: [userId])
  ChatSummary         ChatSummary[]
  ConversationInsight ConversationInsight[]
  CrisisAlert         CrisisAlert[]
  Message             Message[]

  @@index([athleteId])
  @@index([createdAt])
}

model ChatSummary {
  id             String      @id
  sessionId      String
  athleteId      String
  coachId        String?
  summary        String
  keyThemes      Json
  emotionalState String?
  actionItems    Json?
  messageCount   Int
  generatedAt    DateTime    @default(now())
  viewedByCoach  Boolean     @default(false)
  viewedAt       DateTime?
  Athlete        Athlete     @relation(fields: [athleteId], references: [userId])
  ChatSession    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([athleteId, generatedAt])
  @@index([sessionId])
  @@index([viewedByCoach])
}

model Coach {
  userId    String      @id
  sport     String
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime
  User      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  CoachNote CoachNote[]
}

model CoachNote {
  id        String   @id
  coachId   String
  athleteId String
  content   String
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Coach     Coach    @relation(fields: [coachId], references: [userId])

  @@index([athleteId])
  @@index([coachId])
}

model ConversationInsight {
  id             String      @id
  athleteId      String
  sessionId      String
  themes         Json
  sentiment      Float
  emotions       Json?
  discoveryPhase String?
  extractedAt    DateTime    @default(now())
  Athlete        Athlete     @relation(fields: [athleteId], references: [userId])
  ChatSession    ChatSession @relation(fields: [sessionId], references: [id])

  @@index([athleteId, extractedAt])
}

model CrisisAlert {
  id          String      @id
  athleteId   String
  sessionId   String
  messageId   String
  severity    Severity
  detectedAt  DateTime    @default(now())
  reviewed    Boolean     @default(false)
  reviewedBy  String?
  reviewedAt  DateTime?
  escalated   Boolean     @default(false)
  escalatedTo String?
  notes       String?
  Athlete     Athlete     @relation(fields: [athleteId], references: [userId])
  Message     Message     @relation(fields: [messageId], references: [id])
  ChatSession ChatSession @relation(fields: [sessionId], references: [id])

  @@index([athleteId, detectedAt])
  @@index([severity, reviewed])
}

model Goal {
  id          String       @id
  athleteId   String
  title       String
  description String?
  category    GoalCategory
  status      GoalStatus   @default(IN_PROGRESS)
  targetDate  DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  Athlete     Athlete      @relation(fields: [athleteId], references: [userId])

  @@index([athleteId])
  @@index([status])
}

model KnowledgeBase {
  id        String            @id
  title     String
  content   String
  source    String
  sourceUrl String?
  embedding Json?
  category  KnowledgeCategory
  tags      String
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime
  schoolId  String?
  School    School?           @relation(fields: [schoolId], references: [id])

  @@index([category])
  @@index([isActive])
  @@index([schoolId])
}

model Message {
  id          String        @id
  sessionId   String
  role        MessageRole
  content     String
  embedding   Json?
  createdAt   DateTime      @default(now())
  CrisisAlert CrisisAlert[]
  ChatSession ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([sessionId])
}

model MoodLog {
  id         String   @id
  athleteId  String
  mood       Int
  confidence Int
  stress     Int
  energy     Int?
  sleep      Int?
  notes      String?
  tags       String
  createdAt  DateTime @default(now())
  Athlete    Athlete  @relation(fields: [athleteId], references: [userId])

  @@index([athleteId])
  @@index([createdAt])
}

model PerformanceMetric {
  id                String   @id
  athleteId         String
  gameDate          DateTime
  sport             String
  opponentName      String?
  mentalMoodScore   Int?
  mentalStressScore Int?
  mentalSleepHours  Float?
  mentalHRVScore    Int?
  stats             Json
  outcome           String
  readinessScore    Int?
  slumpPrediction   Boolean?
  createdAt         DateTime @default(now())
  Athlete           Athlete  @relation(fields: [athleteId], references: [userId])

  @@index([athleteId, gameDate])
  @@index([sport])
}

model ReadinessScore {
  id             String   @id
  athleteId      String
  gameDate       DateTime
  calculatedAt   DateTime @default(now())
  score          Int
  level          String
  factors        Json
  moodAvg7d      Float
  stressAvg7d    Float
  sleepAvg3d     Float
  hrvRecovery    Float?
  daysSinceGame  Int?
  chatEngagement Int?
  Athlete        Athlete  @relation(fields: [athleteId], references: [userId])

  @@index([athleteId, gameDate])
  @@index([level])
}

model School {
  id            String          @id
  name          String
  division      String
  customConfig  Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  KnowledgeBase KnowledgeBase[]
  TeamConfig    TeamConfig[]
  User          User[]

  @@index([name])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TeamConfig {
  id              String   @id
  schoolId        String
  sport           String
  customPrompts   Json?
  customKeywords  Json?
  customResources Json?
  updatedBy       String?
  updatedAt       DateTime
  createdAt       DateTime @default(now())
  School          School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, sport])
  @@index([sport])
}

model User {
  id                  String    @id
  email               String    @unique
  emailVerified       DateTime?
  name                String
  password            String?
  image               String?
  role                Role      @default(ATHLETE)
  onboardingCompleted Boolean   @default(false)
  schoolId            String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime
  Account             Account[]
  Athlete             Athlete?
  Coach               Coach?
  Session             Session[]
  School              School    @relation(fields: [schoolId], references: [id])

  @@index([email])
  @@index([schoolId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WearableData {
  id         String   @id
  athleteId  String
  deviceType String
  metricType String
  value      Float
  unit       String?
  recordedAt DateTime
  syncedAt   DateTime @default(now())
  Athlete    Athlete  @relation(fields: [athleteId], references: [userId])

  @@index([athleteId, metricType, recordedAt])
  @@index([deviceType])
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  REVIEWED
}

enum GoalCategory {
  PERFORMANCE
  MENTAL
  ACADEMIC
  PERSONAL
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum KnowledgeCategory {
  ANXIETY
  CONFIDENCE
  FOCUS
  RECOVERY
  GOAL_SETTING
  MOTIVATION
  TEAM_DYNAMICS
  STRESS_MANAGEMENT
  PERFORMANCE_ANXIETY
  FLOW_STATE
  SELF_TALK
  VISUALIZATION
  MINDFULNESS
  BURNOUT
}

enum MessageRole {
  user
  assistant
  system
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Role {
  ATHLETE
  COACH
  ADMIN
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}
