# ============================================
# SERVER CONFIGURATION
# ============================================
ENVIRONMENT=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_sports_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================
# OPENAI
# ============================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# ============================================
# FIREBASE AUTH
# ============================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# Or use service account JSON file path
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ============================================
# VECTOR DATABASE
# ============================================
# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=sports_psych_kb

# Alternative: Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=

# ============================================
# REDIS (for caching & sessions)
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
CACHE_TTL=3600

# ============================================
# SECURITY
# ============================================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# MULTI-TENANCY
# ============================================
# Default school/tenant ID
DEFAULT_SCHOOL_ID=uw_madison
ENABLE_MULTI_TENANT=true

# ============================================
# AGENT CONFIGURATION
# ============================================
# AthleteAgent
ATHLETE_AGENT_MODEL=gpt-4-turbo-preview
ATHLETE_AGENT_TEMPERATURE=0.7
ATHLETE_AGENT_MAX_TOKENS=2000

# CoachAgent
COACH_AGENT_MODEL=gpt-4-turbo-preview
COACH_AGENT_TEMPERATURE=0.5
COACH_AGENT_MAX_TOKENS=1500

# GovernanceAgent
GOVERNANCE_AGENT_MODEL=gpt-4-turbo-preview
GOVERNANCE_AGENT_TEMPERATURE=0.3
ENABLE_CRISIS_DETECTION=true
CRISIS_ESCALATION_EMAIL=crisis-team@university.edu

# KnowledgeAgent
KNOWLEDGE_CHUNK_SIZE=1000
KNOWLEDGE_CHUNK_OVERLAP=200
KNOWLEDGE_TOP_K=5
KNOWLEDGE_SIMILARITY_THRESHOLD=0.7

# ============================================
# DISCOVERY-FIRST PROTOCOL
# ============================================
ENABLE_DISCOVERY_PROTOCOL=true
DISCOVERY_MIN_QUESTIONS=3
DISCOVERY_MAX_QUESTIONS=7

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090

# ============================================
# CELERY (Background Tasks)
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# FILE STORAGE
# ============================================
# For PDF uploads and processing
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
