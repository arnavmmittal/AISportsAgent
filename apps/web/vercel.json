{
  "installCommand": "npm install --legacy-peer-deps",
  "crons": [
    {
      "path": "/api/cron/escalation",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/generate-weekly-summaries",
      "schedule": "59 23 * * 0"
    },
    {
      "path": "/api/cron/cleanup-summaries",
      "schedule": "0 2 * * *"
    }
  ]
}
