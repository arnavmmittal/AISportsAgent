# ============================================
# SUPABASE (PRIMARY DATABASE + AUTH)
# ============================================

# Database connection string
# Get from: Supabase Dashboard → Settings → Database → Connection string (Transaction mode)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Supabase API
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ============================================
# ENVIRONMENT
# ============================================

# Environment: development | production | test
NEXT_PUBLIC_ENV="development"

# Enable demo accounts (NEVER true in production)
NEXT_PUBLIC_ENABLE_DEMO_ACCOUNTS="true"

# ============================================
# COST CONTROLS (CRITICAL)
# ============================================

# Daily token limit per user (recommended: 20 messages = ~100 tokens)
COST_LIMIT_DAILY_PER_USER=100

# Monthly total token limit (safety ceiling)
COST_LIMIT_MONTHLY_TOTAL=2000

# ============================================
# NEXTAUTH (Legacy - will migrate to Supabase Auth)
# ============================================

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-this-in-production"

# Your application URL
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# WEEKLY CHAT SUMMARIES (Privacy & Security)
# ============================================

# Cron job authentication secret
# Generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here-change-this-in-production"

# Field-level encryption key for sensitive summary data (32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
SUMMARY_ENCRYPTION_KEY="your-encryption-key-here-64-hex-characters"

# ============================================
# AI SERVICES (REQUIRED FOR AGENT SYSTEM)
# ============================================

# OPENAI - All AI functionality (conversation, crisis detection, embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Model for AthleteAgent and GovernanceAgent
# Options: gpt-4-turbo-preview, gpt-4-0125-preview, gpt-4-1106-preview, gpt-3.5-turbo
OPENAI_MODEL="gpt-4-turbo-preview"

# Embedding model for KnowledgeAgent
# Options: text-embedding-3-small, text-embedding-3-large
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ============================================
# MCP SERVER (DEPRECATED - NOT REQUIRED)
# ============================================
# The Python MCP server has been deprecated in favor of Vercel-only deployment.
# Voice now uses local API routes with ElevenLabs + OpenAI Whisper.
# Chat uses LangGraph agents directly in Next.js.
# Analytics use TypeScript algorithms in /lib/analytics.
#
# MCP server code is archived in services/_deprecated/mcp-server
#
# These variables are NO LONGER REQUIRED for normal operation:
# MCP_SERVER_URL=""
# NEXT_PUBLIC_API_URL=""
# MCP_SERVICE_TOKEN=""
USE_MCP_SERVER="false"

# ============================================
# AGENT SYSTEM CONFIGURATION
# ============================================

# Enable LangGraph agent orchestration (v2 API)
# Set to "true" to use LangGraph StateGraph for chat
# Uses /api/chat/stream-v2 endpoint
ENABLE_LANGGRAPH="false"

# LangSmith API Key (for observability/tracing)
# Get from: https://smith.langchain.com
LANGSMITH_API_KEY=""

# Enable AI-powered crisis detection (Layer 2)
# Set to "false" to use regex-only detection (faster, less accurate)
ENABLE_AI_CRISIS_DETECTION="true"

# Enable vector search for knowledge retrieval
# Set to "false" to use keyword matching (faster, less accurate)
ENABLE_VECTOR_SEARCH="true"

# Use custom PDF knowledge base (AI Sports Psych Project.pdf)
# Set to "false" to use built-in knowledge base
USE_PDF_KNOWLEDGE_BASE="true"

# ============================================
# REDIS/KV (Real-time features: activity, rate limiting)
# ============================================

# Option 1: Vercel KV (recommended for Vercel deployments)
# Get from: Vercel Dashboard → Storage → Create KV Database
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# Option 2: Upstash Redis (alternative, also serverless)
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Note: If no Redis is configured, falls back to in-memory (dev only)

# ============================================
# VECTOR DATABASE (Optional - for RAG)
# ============================================

# Option 1: Pinecone
PINECONE_API_KEY=""
PINECONE_ENVIRONMENT=""
PINECONE_INDEX=""

# Option 2: Supabase pgvector (if using Supabase)
# Use the same DATABASE_URL as above

# ============================================
# VOICE (REQUIRED FOR VOICE FEATURES)
# ============================================
# Voice is handled entirely by Vercel serverless functions:
# - TTS: ElevenLabs via /api/voice/synthesize
# - STT: OpenAI Whisper via /api/voice/transcribe

# ElevenLabs API Key (REQUIRED for text-to-speech)
# Get from: https://elevenlabs.io/app/api-keys
# Free tier: 10,000 characters/month
ELEVENLABS_API_KEY=""

# Speech-to-text uses OpenAI Whisper via OPENAI_API_KEY (defined above)
# No additional configuration needed for STT

# ============================================
# EMAIL (SendGrid - for notifications)
# ============================================

# SendGrid API Key (for transactional emails)
# Get from: https://sendgrid.com
SENDGRID_API_KEY=""

# From email address (must be verified in SendGrid)
EMAIL_FROM="noreply@aisportsagent.com"

# Resend API Key (alternative, for transactional emails)
RESEND_API_KEY=""

# ============================================
# CRISIS ESCALATION
# ============================================

# Emergency email for escalated alerts (Level 2+)
CRISIS_EMERGENCY_EMAIL=""

# Emergency phone for critical alerts (Level 3+, requires Twilio)
CRISIS_EMERGENCY_PHONE=""

# Twilio (optional - for SMS escalation of CRITICAL alerts)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ============================================
# PUSH NOTIFICATIONS (Expo)
# ============================================

# Expo Access Token (for higher rate limits)
# Get from: https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=""

# Voice service internal authentication key
# Generate with: openssl rand -base64 32
VOICE_SERVICE_KEY="dev-voice-service-key"

# ============================================
# MONITORING (Sentry - Recommended)
# ============================================

# Sentry DSN (Error Tracking)
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry Org and Project (for source maps upload)
# Get from: https://sentry.io → Organization Settings
SENTRY_ORG=""
SENTRY_PROJECT=""

# Sentry Auth Token (for CI/CD source map upload)
# Get from: https://sentry.io → User Settings → API Keys
SENTRY_AUTH_TOKEN=""

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""
