{
  "installCommand": "npm install -g pnpm@9.15.4 && pnpm install --no-frozen-lockfile --filter web...",
  "crons": [
    {
      "path": "/api/cron/escalation",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/generate-weekly-summaries",
      "schedule": "59 23 * * 0"
    },
    {
      "path": "/api/cron/cleanup-summaries",
      "schedule": "0 2 * * *"
    }
  ]
}
