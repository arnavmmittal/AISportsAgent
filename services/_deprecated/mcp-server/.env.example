# ============================================
# AI SPORTS AGENT - MCP SERVER CONFIGURATION
# ============================================

# CRITICAL: Copy this file to .env and fill in real values
# NEVER commit .env to version control (.env is in .gitignore)

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development  # development, staging, production
DEBUG=true  # Set to false in production
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text

# ============================================
# SERVER CONFIGURATION
# ============================================
APP_NAME="AI Sports Psychology MCP Server"
APP_VERSION="1.0.0"
HOST=0.0.0.0
PORT=8000
RELOAD=true  # Auto-reload on file changes (development only)
WORKERS=4  # Number of Gunicorn workers (production)

# ============================================
# DATABASE (Supabase PostgreSQL)
# ============================================
DATABASE_URL="postgresql://user:password@host:5432/database"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false  # Set to true to log all SQL queries (debugging only)

# ============================================
# AI SERVICES (Server-only keys - NEVER expose to client)
# ============================================

# OpenAI Configuration
OPENAI_API_KEY="sk-proj-..."
OPENAI_MODEL="gpt-4-turbo-preview"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_MAX_TOKENS=2000  # Hard cap per response
OPENAI_TEMPERATURE=0.7

# Anthropic Configuration (Backup provider - optional)
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-3-opus-20240229"

# Voice Services
CARTESIA_API_KEY=""  # Leave empty to use OpenAI TTS only
CARTESIA_VOICE_ID="voice-id-supportive"
WHISPER_MODEL="whisper-1"

# ============================================
# VECTOR DATABASE (ChromaDB)
# ============================================
CHROMA_HOST=""  # Leave empty for local, or "https://api.chroma.cloud" for managed
CHROMA_PORT=8000  # Only for local deployment
CHROMA_API_KEY=""  # Only if using Chroma Cloud
CHROMA_PERSIST_DIRECTORY="./chroma_data"  # Local storage path
CHROMA_COLLECTION_NAME="sports_psychology_kb"
CHROMA_COLLECTION_PREFIX="kb_"  # Prefix for tenant collections

# ============================================
# SECURITY & AUTHENTICATION
# ============================================

# JWT Configuration
JWT_SECRET_KEY="CHANGE_ME_USE_openssl_rand_base64_32"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# NextAuth (from Next.js frontend)
NEXTAUTH_SECRET="your-nextauth-secret-from-nextjs"
NEXTAUTH_URL="http://localhost:3000"

# Service-to-Service Authentication (for Next.js → MCP auth)
MCP_SERVICE_TOKEN="CHANGE_ME_MINIMUM_32_CHARS"

# CORS Configuration (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
CORS_ALLOW_CREDENTIALS=true

# ============================================
# COST CONTROLS (CRITICAL FOR PRODUCTION)
# ============================================
ENABLE_COST_LIMITS=true  # MUST be true in production
COST_LIMIT_DAILY_PER_TENANT=500  # USD per tenant per day
COST_LIMIT_MONTHLY_TOTAL=10000  # USD total per month
CIRCUIT_BREAKER_THRESHOLD=500  # Trigger circuit breaker at this cost (USD/day)
COST_WARNING_THRESHOLD=400  # Send warning at 80% of limit (USD/day)

# Token Budgets
MAX_TOKENS_PER_REQUEST=2000
MAX_TOKENS_PER_USER_DAILY=100000  # ~$0.20/day at GPT-4 prices
MAX_TOKENS_PER_TENANT_DAILY=1000000  # ~$2/day at GPT-4 prices

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60  # Default requests per minute
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PER_USER=60  # Requests per minute per user
RATE_LIMIT_PER_TENANT=1000  # Requests per minute per tenant
RATE_LIMIT_GLOBAL=10000  # Requests per minute (total)

# Endpoint-Specific Limits
RATE_LIMIT_CHAT=20  # Chat requests per minute per user
RATE_LIMIT_VOICE=10  # Concurrent voice connections per user
RATE_LIMIT_ANALYTICS=100  # Analytics requests per minute

# ============================================
# REDIS (for rate limiting, caching, circuit breakers)
# ============================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""  # Leave empty for local dev
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# Circuit Breaker Settings
CIRCUIT_BREAKER_TTL=86400  # 24 hours in seconds
CIRCUIT_BREAKER_REDIS_KEY_PREFIX="circuit_breaker:"

# ============================================
# MONITORING & LOGGING
# ============================================

# Sentry (Error Tracking - optional but recommended)
SENTRY_DSN=""  # Leave empty to disable
SENTRY_ENVIRONMENT=development  # development, staging, production
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% of transactions

# Structured Logging
ENABLE_STRUCTURED_LOGGING=true
LOG_FILE_PATH="./logs/mcp-server.log"

# Metrics (Prometheus - optional)
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================
# CRISIS DETECTION & SAFETY
# ============================================
ENABLE_AI_CRISIS_DETECTION=true  # Use AI + regex (more accurate)
ENABLE_REGEX_CRISIS_DETECTION=true  # Fallback to regex if AI fails

# Crisis Alert Configuration
CRISIS_ALERT_EMAIL="sports-psychology-team@university.edu"
CRISIS_ALERT_WEBHOOK="https://your-webhook-url.com/crisis-alert"
CRISIS_ALERT_SMS_NUMBER="+1234567890"
CRISIS_ESCALATION_TIMEOUT_SECONDS=300  # 5 minutes

# Human Review Queue
ENABLE_HUMAN_REVIEW_QUEUE=true
HUMAN_REVIEW_THRESHOLD_SCORE=0.7  # 0-1, crisis detection confidence threshold

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_DEMO_ACCOUNTS=true  # MUST be false in production
ENABLE_VOICE_CHAT=true
ENABLE_KNOWLEDGE_BASE=true
ENABLE_WEEKLY_SUMMARIES=true
ENABLE_MULTI_MODAL_ANALYTICS=false  # Not yet implemented

# PostHog (Optional - for feature flags)
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ============================================
# BACKGROUND JOBS (Arq - optional)
# ============================================
ENABLE_BACKGROUND_JOBS=true
ARQ_REDIS_URL="redis://localhost:6379"
ARQ_MAX_JOBS=10

# Cron Schedule (use cron syntax)
CRON_WEEKLY_SUMMARIES="0 9 * * MON"  # Every Monday at 9 AM
CRON_COST_AGGREGATION="0 * * * *"  # Every hour

# ============================================
# KNOWLEDGE BASE (PDF Ingestion)
# ============================================
KB_CHUNK_SIZE=1000  # Tokens per chunk
KB_CHUNK_OVERLAP=200  # Token overlap between chunks
KB_MIN_CHUNK_SIZE=100
KB_PDF_STORAGE_PATH="./knowledge_pdfs"
KB_MAX_PDF_SIZE_MB=50  # Maximum PDF size

# Auto-Tagging
KB_AUTO_TAG_WITH_GPT4=true  # Use GPT-4 to auto-tag chunks (costs extra)

# ============================================
# AGENT CONFIGURATION
# ============================================

# Discovery Protocol
DISCOVERY_MIN_QUESTIONS=5
DISCOVERY_MAX_QUESTIONS=10

# AthleteAgent Settings
ATHLETE_AGENT_SYSTEM_PROMPT_PATH="./prompts/athlete_agent_system.txt"
ATHLETE_AGENT_MAX_TURNS=20

# CoachAgent Settings
COACH_AGENT_ANONYMIZE_DATA=true  # Always anonymize athlete data for coaches
COACH_AGENT_CONSENT_REQUIRED=true  # Require consent before sharing data

# ============================================
# VALIDATION & SAFETY
# ============================================
ENABLE_ENV_VALIDATION=true  # Validate environment variables on startup
REQUIRE_HTTPS=false  # Set to true in production

# Input Sanitization
ENABLE_INPUT_SANITIZATION=true
MAX_MESSAGE_LENGTH=2000  # Characters
MAX_SESSION_MESSAGES=100  # Messages per session

# PII Redaction
ENABLE_PII_REDACTION=true  # Remove PII before sending to LLM
PII_REDACTION_PATTERNS="email,phone,ssn,credit_card"

# ============================================
# WEBHOOKS & INTEGRATIONS
# ============================================
WEBHOOK_CRISIS_ALERT_URL=""  # Send crisis alerts to external system
WEBHOOK_WEEKLY_SUMMARY_URL=""  # Send weekly summaries
WEBHOOK_SECRET=""  # HMAC secret for webhook verification
WEBHOOK_TIMEOUT_SECONDS=10

# ============================================
# DEVELOPMENT & DEBUGGING
# ============================================
ENABLE_DEBUG_ENDPOINTS=false  # Exposes /debug/* endpoints (NEVER in production)
ENABLE_API_DOCS=true  # FastAPI /docs endpoint

# Health Checks
HEALTH_CHECK_PATH="/health"
READINESS_CHECK_PATH="/ready"

# ============================================
# PRODUCTION VALIDATION RULES
# ============================================
#
# The following validations are enforced when ENABLE_ENV_VALIDATION=true:
#
# Production Environment (ENVIRONMENT=production):
# - ENABLE_DEMO_ACCOUNTS must be false
# - ENABLE_COST_LIMITS must be true
# - DEBUG must be false
# - REQUIRE_HTTPS must be true
# - JWT_SECRET_KEY must be at least 32 characters
# - MCP_SERVICE_TOKEN must be at least 32 characters
# - CRISIS_ALERT_EMAIL must be set
#
# All Environments:
# - DATABASE_URL must be a valid PostgreSQL URL
# - OPENAI_API_KEY must start with "sk-"
# - REDIS_URL must be a valid Redis URL (if rate limiting enabled)

# ============================================
# QUICK START
# ============================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate secrets:
#    openssl rand -base64 32  # For JWT_SECRET_KEY
#    openssl rand -base64 32  # For MCP_SERVICE_TOKEN
#
# 3. Fill in required values:
#    - DATABASE_URL (from Supabase dashboard)
#    - OPENAI_API_KEY (from OpenAI dashboard)
#    - CRISIS_ALERT_EMAIL (your team's email)
#    - NEXTAUTH_SECRET (from Next.js .env)
#
# 4. Start the server:
#    uvicorn app.main:app --reload
#
# 5. Test health check:
#    curl http://localhost:8000/health
#
# See ProductionSecurityRunbook.md for complete deployment guide
