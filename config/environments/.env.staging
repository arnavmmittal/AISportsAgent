# ============================================
# STAGING ENVIRONMENT
# ============================================
# Deploy to Vercel staging project with these variables

# Environment
NODE_ENV=staging
NEXT_PUBLIC_APP_URL=https://staging.aisportsagent.com

# Database (Staging Supabase)
DATABASE_URL=postgresql://postgres.[STAGING_PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[STAGING_PROJECT].supabase.co
SUPABASE_ANON_KEY=eyJ...  # Staging-specific key
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # NEVER expose to client

# Auth (rotate every 90 days)
NEXTAUTH_SECRET=[ROTATE_EVERY_90_DAYS]
NEXTAUTH_URL=https://staging.aisportsagent.com

# AI Services (separate staging keys)
OPENAI_API_KEY=sk-proj-staging-...
OPENAI_MODEL=gpt-4-turbo-preview  # Match production
OPENAI_MAX_TOKENS=2000

# MCP Server (Railway staging)
MCP_SERVER_URL=https://mcp-staging.railway.app
MCP_SERVICE_TOKEN=[STAGING_SERVICE_TOKEN]

# Feature Flags (Staging - production-like)
ENABLE_DEMO_ACCOUNTS=false       # MUST be false
ENABLE_COST_LIMITS=true          # MUST be true
COST_LIMIT_DAILY=100             # USD per tenant
COST_LIMIT_MONTHLY=2000          # USD total
ENABLE_VOICE=true
ENABLE_ADVANCED_ANALYTICS=true

# Monitoring
SENTRY_DSN=https://...@sentry.io/staging
SENTRY_ENV=staging
LOG_LEVEL=info

# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_USER=60           # requests/minute
RATE_LIMIT_PER_TENANT=1000       # requests/minute

# WebSocket
NEXT_PUBLIC_WEBSOCKET_URL=wss://ws-staging.aisportsagent.com
