generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Assignment {
  id                   String                 @id @default(cuid())
  coachId              String
  title                String
  description          String
  dueDate              DateTime?
  targetAthleteIds     Json?
  targetSport          String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  AssignmentSubmission AssignmentSubmission[]

  @@index([coachId])
  @@index([dueDate])
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  athleteId    String
  response     String?
  status       AssignmentStatus @default(PENDING)
  submittedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  Assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, athleteId])
  @@index([assignmentId])
  @@index([athleteId])
  @@index([status])
}

model Athlete {
  userId               String                @id
  sport                String
  year                 String
  teamPosition         String?
  consentCoachView     Boolean               @default(false)
  riskLevel            RiskLevel             @default(LOW)
  lastRiskUpdate       DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  consentChatSummaries Boolean               @default(false)
  User                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  ChatSession          ChatSession[]
  ChatSummary          ChatSummary[]
  ConversationInsight  ConversationInsight[]
  CrisisAlert          CrisisAlert[]
  Goal                 Goal[]
  MoodLog              MoodLog[]
  PerformanceMetric    PerformanceMetric[]
  ReadinessScore       ReadinessScore[]
  WearableData         WearableData[]
  Task                 Task[]
  TaskPattern          TaskPattern[]

  @@index([riskLevel])
  @@index([sport])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  userRole     Role
  action       String
  resourceType String
  resourceId   String?
  athleteId    String?
  ipAddress    String?
  userAgent    String?
  timestamp    DateTime @default(now())

  @@index([action])
  @@index([athleteId, timestamp])
  @@index([userId, timestamp])
}

model ChatSession {
  id                  String                @id @default(cuid())
  athleteId           String
  summary             String?
  topic               String?
  sentiment           String?

  // Elite Sports Psychology System fields (Phase 1)
  discoveryPhase      String?               @default("check_in")
  phaseStartedAt      DateTime?
  sessionGoals        Json?
  focusArea           String?
  systemContext       Json?
  isActive            Boolean               @default(true)

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  Athlete             Athlete               @relation(fields: [athleteId], references: [userId])
  ChatSummary         ChatSummary[]
  ConversationInsight ConversationInsight[]
  CrisisAlert         CrisisAlert[]
  Message             Message[]

  @@index([athleteId])
  @@index([createdAt])
}

model ChatSummary {
  id             String      @id @default(cuid())
  sessionId      String
  athleteId      String
  coachId        String?
  summary        String
  keyThemes      Json
  emotionalState String?
  actionItems    Json?
  messageCount   Int
  generatedAt    DateTime    @default(now())
  viewedByCoach  Boolean     @default(false)
  viewedAt       DateTime?
  Athlete        Athlete     @relation(fields: [athleteId], references: [userId])
  ChatSession    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([athleteId, generatedAt])
  @@index([sessionId])
  @@index([viewedByCoach])
}

model Coach {
  userId    String      @id
  sport     String
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime
  User      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  CoachNote CoachNote[]
}

model CoachNote {
  id        String   @id @default(cuid())
  coachId   String
  athleteId String
  content   String
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Coach     Coach    @relation(fields: [coachId], references: [userId])

  @@index([athleteId])
  @@index([coachId])
}

model ConversationInsight {
  id             String      @id @default(cuid())
  athleteId      String
  sessionId      String
  themes         Json
  sentiment      Float
  emotions       Json?
  discoveryPhase String?
  extractedAt    DateTime    @default(now())
  Athlete        Athlete     @relation(fields: [athleteId], references: [userId])
  ChatSession    ChatSession @relation(fields: [sessionId], references: [id])

  @@index([athleteId, extractedAt])
}

model CrisisAlert {
  id          String      @id @default(cuid())
  athleteId   String
  sessionId   String
  messageId   String
  severity    Severity
  detectedAt  DateTime    @default(now())
  reviewed    Boolean     @default(false)
  reviewedBy  String?
  reviewedAt  DateTime?
  escalated   Boolean     @default(false)
  escalatedTo String?
  notes       String?
  Athlete     Athlete     @relation(fields: [athleteId], references: [userId])
  Message     Message     @relation(fields: [messageId], references: [id])
  ChatSession ChatSession @relation(fields: [sessionId], references: [id])

  @@index([athleteId, detectedAt])
  @@index([severity, reviewed])
}

model Goal {
  id          String       @id @default(cuid())
  athleteId   String
  title       String
  description String?
  category    GoalCategory
  type        GoalType     @default(SHORT_TERM)
  status      GoalStatus   @default(IN_PROGRESS)

  // Progress tracking
  targetMetric    String?
  currentValue    Float?
  targetValue     Float?
  unit            String?
  completionPct   Int       @default(0)

  // Timeline
  startDate       DateTime  @default(now())
  targetDate  DateTime?
  completedAt DateTime?

  // Hierarchy
  parentGoalId    String?
  parentGoal      Goal?     @relation("GoalHierarchy", fields: [parentGoalId], references: [id])
  childGoals      Goal[]    @relation("GoalHierarchy")

  // Related tasks
  tasks           Task[]

  // Metadata
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  Athlete     Athlete      @relation(fields: [athleteId], references: [userId])

  @@index([athleteId])
  @@index([status])
  @@index([type])
  @@index([parentGoalId])
}

model KnowledgeBase {
  id        String            @id
  title     String
  content   String
  source    String
  sourceUrl String?
  embedding Json?
  category  KnowledgeCategory
  tags      String
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime
  schoolId  String?
  School    School?           @relation(fields: [schoolId], references: [id])

  @@index([category])
  @@index([isActive])
  @@index([schoolId])
}

model Message {
  id          String        @id
  sessionId   String
  role        MessageRole
  content     String
  embedding   Json?
  createdAt   DateTime      @default(now())
  CrisisAlert CrisisAlert[]
  ChatSession ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([sessionId])
}

model MoodLog {
  id         String   @id @default(cuid())
  athleteId  String
  mood       Int
  confidence Int
  stress     Int
  energy     Int?
  sleep      Int?
  notes      String?
  tags       String
  createdAt  DateTime @default(now())
  Athlete    Athlete  @relation(fields: [athleteId], references: [userId])

  @@index([athleteId])
  @@index([createdAt])
}

model PerformanceMetric {
  id                String   @id @default(cuid())
  athleteId         String
  gameDate          DateTime
  sport             String
  opponentName      String?
  mentalMoodScore   Int?
  mentalStressScore Int?
  mentalSleepHours  Float?
  mentalHRVScore    Int?
  stats             Json
  outcome           String
  readinessScore    Int?
  slumpPrediction   Boolean?
  createdAt         DateTime @default(now())
  Athlete           Athlete  @relation(fields: [athleteId], references: [userId])

  @@index([athleteId, gameDate])
  @@index([sport])
}

model ReadinessScore {
  id             String   @id
  athleteId      String
  gameDate       DateTime
  calculatedAt   DateTime @default(now())
  score          Int
  level          String
  factors        Json
  moodAvg7d      Float
  stressAvg7d    Float
  sleepAvg3d     Float
  hrvRecovery    Float?
  daysSinceGame  Int?
  chatEngagement Int?
  Athlete        Athlete  @relation(fields: [athleteId], references: [userId])

  @@index([athleteId, gameDate])
  @@index([level])
}

model School {
  id            String          @id
  name          String
  division      String
  customConfig  Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  KnowledgeBase KnowledgeBase[]
  TeamConfig    TeamConfig[]
  User          User[]

  @@index([name])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TeamConfig {
  id              String   @id @default(cuid())
  schoolId        String
  sport           String
  customPrompts   Json?
  customKeywords  Json?
  customResources Json?
  updatedBy       String?
  updatedAt       DateTime
  createdAt       DateTime @default(now())
  School          School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, sport])
  @@index([sport])
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  emailVerified       DateTime?
  name                String
  password            String?
  image               String?
  role                Role           @default(ATHLETE)
  onboardingCompleted Boolean        @default(false)
  schoolId            String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  Account             Account[]
  Athlete             Athlete?
  Coach               Coach?
  Session             Session[]
  UserSettings        UserSettings?
  School              School         @relation(fields: [schoolId], references: [id])

  @@index([email])
  @@index([schoolId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WearableData {
  id         String   @id @default(cuid())
  athleteId  String
  deviceType String
  metricType String
  value      Float
  unit       String?
  recordedAt DateTime
  syncedAt   DateTime @default(now())
  Athlete    Athlete  @relation(fields: [athleteId], references: [userId])

  @@index([athleteId, metricType, recordedAt])
  @@index([deviceType])
}

model Task {
  id              String        @id @default(cuid())
  athleteId       String
  title           String
  description     String?
  category        TaskCategory  @default(OTHER)
  priority        TaskPriority  @default(MEDIUM)
  status          TaskStatus    @default(TODO)
  estimatedTime   Int?
  dueDate         DateTime?
  completionPct   Int           @default(0)
  notes           String?
  tags            String
  attachments     Json?

  aiSuggested     Boolean       @default(false)
  aiReason        String?

  goalId          String?
  goal            Goal?         @relation(fields: [goalId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?

  athlete         Athlete       @relation(fields: [athleteId], references: [userId])

  @@index([athleteId, dueDate])
  @@index([status])
  @@index([goalId])
}

model TaskPattern {
  id              String        @id @default(cuid())
  athleteId       String
  weekStart       DateTime

  totalTasks      Int
  completedTasks  Int
  completionRate  Float

  performanceRate Float?
  mentalRate      Float?
  academicRate    Float?

  mostProductiveTime String?
  avgTasksPerDay  Float?

  currentStreak   Int           @default(0)
  longestStreak   Int           @default(0)

  totalHours      Float?
  loadStatus      String?

  calculatedAt    DateTime      @default(now())

  athlete         Athlete       @relation(fields: [athleteId], references: [userId])

  @@unique([athleteId, weekStart])
  @@index([athleteId, weekStart])
}

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique

  pushEnabled           Boolean  @default(true)
  taskReminders         Boolean  @default(true)
  taskReminderTimes     String   @default("15m,1h")
  goalMilestones        Boolean  @default(true)
  assignmentNotifs      Boolean  @default(true)
  chatMessages          Boolean  @default(false)
  weeklyEmail           Boolean  @default(true)
  weeklyEmailDay        String   @default("Sunday")
  weeklyEmailTime       String   @default("18:00")

  shareChatsWithCoach   Boolean  @default(false)
  shareMoodWithCoach    Boolean  @default(false)
  shareGoalsWithCoach   Boolean  @default(false)

  conversationStyle     String   @default("supportive")
  languageFormality     String   @default("casual")
  responseLength        String   @default("detailed")
  autoSuggestions       Boolean  @default(true)
  patternDetection      Boolean  @default(true)

  primarySport          String?
  secondarySports       String   @default("")
  competitionLevel      String?
  seasonStatus          String?
  trainingFocusAreas    String   @default("")

  theme                 String   @default("dark")
  fontSize              String   @default("medium")

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ErrorLog {
  id              String   @id @default(cuid())
  userId          String?
  errorType       String
  errorName       String
  errorMessage    String
  errorStack      String?

  route           String?
  action          String?
  requestId       String?

  platform        String?
  platformVersion String?
  appVersion      String?

  metadata        Json?

  timestamp       DateTime @default(now())

  @@index([userId, timestamp])
  @@index([errorType, timestamp])
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  REVIEWED
}

enum GoalCategory {
  PERFORMANCE
  MENTAL
  ACADEMIC
  PERSONAL
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum GoalType {
  LONG_TERM
  SHORT_TERM
}

enum TaskCategory {
  PERFORMANCE
  MENTAL
  ACADEMIC
  RECOVERY
  PERSONAL
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  POSTPONED
  CANCELLED
}

enum KnowledgeCategory {
  ANXIETY
  CONFIDENCE
  FOCUS
  RECOVERY
  GOAL_SETTING
  MOTIVATION
  TEAM_DYNAMICS
  STRESS_MANAGEMENT
  PERFORMANCE_ANXIETY
  FLOW_STATE
  SELF_TALK
  VISUALIZATION
  MINDFULNESS
  BURNOUT
}

enum MessageRole {
  user
  assistant
  system
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Role {
  ATHLETE
  COACH
  ADMIN
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}
