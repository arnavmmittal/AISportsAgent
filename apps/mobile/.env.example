# AI Sports Agent Mobile App - Environment Configuration
# Copy this file to .env.local and update with your values

# Backend API URL
# For development: Use your computer's local IP address (find with `ipconfig getifaddr en0` on Mac)
# For production: Use your deployed backend URL
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# MCP Voice Server URL (if different from API)
EXPO_PUBLIC_VOICE_URL=ws://192.168.1.100:8000

# Supabase Configuration (if using direct connection from mobile)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI API Configuration (for Whisper STT)
EXPO_PUBLIC_OPENAI_API_KEY=sk-your-openai-api-key

# ElevenLabs API Configuration (for TTS)
EXPO_PUBLIC_ELEVENLABS_API_KEY=your-elevenlabs-api-key
