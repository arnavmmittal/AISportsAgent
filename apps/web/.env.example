# ============================================
# SUPABASE (PRIMARY DATABASE + AUTH)
# ============================================

# Database connection string
# Get from: Supabase Dashboard → Settings → Database → Connection string (Transaction mode)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Supabase API
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ============================================
# ENVIRONMENT
# ============================================

# Environment: development | production | test
NEXT_PUBLIC_ENV="development"

# Enable demo accounts (NEVER true in production)
NEXT_PUBLIC_ENABLE_DEMO_ACCOUNTS="true"

# ============================================
# COST CONTROLS (CRITICAL)
# ============================================

# Daily token limit per user (recommended: 20 messages = ~100 tokens)
COST_LIMIT_DAILY_PER_USER=100

# Monthly total token limit (safety ceiling)
COST_LIMIT_MONTHLY_TOTAL=2000

# ============================================
# NEXTAUTH (Legacy - will migrate to Supabase Auth)
# ============================================

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-this-in-production"

# Your application URL
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# OPENAI
# ============================================

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Model to use (gpt-4, gpt-4-turbo, gpt-3.5-turbo)
OPENAI_MODEL="gpt-4-turbo-preview"

# ============================================
# VECTOR DATABASE (Optional - for RAG)
# ============================================

# Option 1: Pinecone
PINECONE_API_KEY=""
PINECONE_ENVIRONMENT=""
PINECONE_INDEX=""

# Option 2: Supabase pgvector (if using Supabase)
# Use the same DATABASE_URL as above

# ============================================
# VOICE (Cartesia - Primary)
# ============================================

# Cartesia API Key (for voice STT + TTS)
# Get from: https://cartesia.ai
CARTESIA_API_KEY=""
NEXT_PUBLIC_CARTESIA_API_KEY=""

# Fallback: OpenAI (for Whisper STT + TTS)
# Uses the OPENAI_API_KEY defined above

# ============================================
# VOICE (Optional - Legacy)
# ============================================

# 11Labs API Key
ELEVENLABS_API_KEY=""

# ============================================
# EMAIL (Optional - for notifications)
# ============================================

# Resend API Key (for transactional emails)
RESEND_API_KEY=""

# ============================================
# MONITORING (Optional)
# ============================================

# Sentry DSN
NEXT_PUBLIC_SENTRY_DSN=""

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""
